# Non-secret keys only. Real values live in OCI Vault (plan §15) — never commit .env.
# Copy to .env and fill for local dev; .env is gitignored.

# databento (primary market-data feed) — plan §6.1
DATABENTO_API_KEY=

# FRED (primary historical rates: SOFR / OIS proxy / real rates) — plan §6.3, CEO 2026-07-19
# Free key at https://api.stlouisfed.org. Same no-double-download caching policy as bars.
FRED_API_KEY=

# OCI (Object Storage parquet + NoSQL state + Vault) — plan §3.2, §8, §15
OCI_CONFIG_FILE=~/.oci/config
OCI_CLI_PROFILE=DEFAULT
OCI_OS_NAMESPACE=
OCI_OS_BUCKET_BARS=
OCI_NOSQL_TABLE_PREFIX=personal_strat_pai
# NoSQL compartment OCID — required for `python -m personal_strat_pai.infra.oci.provision`
# (real run; --dry-run does not need it). CEO-gated: the first real provision
# requires CEO sign-off (creating NoSQL tables incurs a small monthly cost).
OCI_NOSQL_COMPARTMENT_ID=

# yfinance fallback needs no key (plan §6.1)

# Logging
LOG_LEVEL=INFO
STRUCTLOG_DEV=1
